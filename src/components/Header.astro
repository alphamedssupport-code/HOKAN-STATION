---
const categories = [
  { name: '基礎知識',   slug: '基礎知識',   color: 'hover:bg-sky-50 hover:text-sky-700' },
  { name: '疾患別ケア', slug: '疾患別ケア', color: 'hover:bg-rose-50 hover:text-rose-700' },
  { name: '家族向け',   slug: '家族向け',   color: 'hover:bg-amber-50 hover:text-amber-700' },
  { name: '制度・保険', slug: '制度・保険', color: 'hover:bg-violet-50 hover:text-violet-700' },
  { name: 'キャリア',   slug: 'キャリア',   color: 'hover:bg-emerald-50 hover:text-emerald-700' },
  { name: '医療技術',   slug: '医療技術',   color: 'hover:bg-orange-50 hover:text-orange-700' },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Logo Row -->
    <div class="flex items-center justify-between py-3 border-b border-gray-100">
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 bg-gradient-to-br from-primary-500 to-primary-700 rounded-xl flex items-center justify-center shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
        </div>
        <div>
          <div class="flex items-baseline gap-1.5">
            <span class="text-lg font-black text-primary-700 tracking-tight group-hover:text-primary-800 transition-colors">HOKAN</span>
            <span class="text-lg font-black text-gray-800 tracking-tight">STATION</span>
          </div>
          <p class="text-[10px] text-gray-400 leading-none tracking-wider uppercase">訪問看護の専門メディア</p>
        </div>
      </a>

      <a href="/about/" class="hidden md:block text-xs text-gray-400 hover:text-primary-600 transition-colors">
        このサイトについて
      </a>
    </div>

    <!-- Category Nav -->
    <nav class="flex items-center gap-0.5 overflow-x-auto py-2 scrollbar-hide">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.slug}/`}
          class={`whitespace-nowrap text-xs font-medium px-3 py-1.5 rounded-lg text-gray-600 transition-colors flex-shrink-0 ${cat.color}`}
        >
          {cat.name}
        </a>
      ))}
    </nav>
  </div>
</header>
