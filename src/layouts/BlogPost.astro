---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updateDate?: Date;
  category: string;
  tags: string[];
  author: string;
}

const { title, description, publishDate, updateDate, category, tags, author } = Astro.props;

const formattedPublishDate = publishDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdateDate = updateDate
  ? updateDate.toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const categoryColorMap: Record<string, { bg: string; text: string; border: string }> = {
  '基礎知識':   { bg: 'bg-sky-100',     text: 'text-sky-800',     border: 'border-sky-300' },
  '疾患別ケア': { bg: 'bg-rose-100',    text: 'text-rose-800',    border: 'border-rose-300' },
  '家族向け':   { bg: 'bg-amber-100',   text: 'text-amber-800',   border: 'border-amber-300' },
  '制度・保険': { bg: 'bg-violet-100',  text: 'text-violet-800',  border: 'border-violet-300' },
  'キャリア':   { bg: 'bg-emerald-100', text: 'text-emerald-800', border: 'border-emerald-300' },
  '医療技術':   { bg: 'bg-orange-100',  text: 'text-orange-800',  border: 'border-orange-300' },
};
const catColor = categoryColorMap[category] ?? { bg: 'bg-gray-100', text: 'text-gray-700', border: 'border-gray-300' };
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishDate={publishDate}
  author={author}
  tags={tags}
>
  <Header />

  <main class="flex-1 bg-gray-50">
    <!-- Article Hero -->
    <div class="bg-white border-b border-gray-100 py-8">
      <div class="max-w-3xl mx-auto px-4 md:px-6">
        <Breadcrumb category={category} title={title} />

        <div class="mt-5">
          <!-- Category Badge -->
          <span class={`inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1.5 rounded-full border ${catColor.bg} ${catColor.text} ${catColor.border}`}>
            {category}
          </span>

          <!-- Title -->
          <h1 class="text-xl md:text-3xl font-bold text-gray-900 leading-snug mt-3 mb-5">
            {title}
          </h1>

          <!-- Description -->
          <p class="text-gray-500 text-sm md:text-base leading-relaxed border-l-4 border-primary-300 pl-4 bg-primary-50 py-3 pr-4 rounded-r-lg">
            {description}
          </p>

          <!-- Meta Info -->
          <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-5 text-sm text-gray-400">
            <div class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <time datetime={publishDate.toISOString()}>公開：{formattedPublishDate}</time>
            </div>
            {formattedUpdateDate && (
              <div class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <time datetime={updateDate?.toISOString()} class="text-accent-600 font-medium">更新：{formattedUpdateDate}</time>
              </div>
            )}
            <div class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              <span>{author}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Article Body -->
    <div class="max-w-3xl mx-auto px-4 md:px-6 py-8">

      <!-- Notice Box -->
      <div class="mb-8 flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 mt-0.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p>本記事は一般的な情報提供を目的としており、医療アドバイスに代わるものではありません。実際の処置・判断は医師・専門家にご相談ください。</p>
      </div>

      <!-- Article Content -->
      <article class="bg-white rounded-2xl shadow-sm border border-gray-100 px-6 py-8 md:px-10 md:py-10">
        <div class="article-body">
          <slot />
        </div>
      </article>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-6 bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">関連タグ</p>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="inline-flex items-center gap-1 bg-gray-50 border border-gray-200 text-gray-600 text-sm px-3 py-1 rounded-full hover:bg-primary-50 hover:border-primary-200 hover:text-primary-700 transition-colors cursor-default">
                <span class="text-primary-400">#</span>{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Author Card -->
      <div class="mt-6 bg-gradient-to-br from-primary-700 to-primary-900 rounded-2xl p-6 text-white">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-base">{author}</p>
            <p class="text-primary-200 text-sm mt-0.5">訪問看護・在宅医療の専門情報を毎日発信。看護師・ケアマネジャー・ご家族に役立つ記事をお届けします。</p>
          </div>
        </div>
      </div>

      <!-- Back to Top -->
      <div class="mt-8 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-primary-600 hover:text-primary-800 font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          記事一覧に戻る
        </a>
      </div>
    </div>
  </main>

  <Footer />

  <!-- Back to Top Button -->
  <button
    id="back-to-top"
    class="fixed bottom-6 right-6 z-50 w-11 h-11 bg-primary-600 hover:bg-primary-700 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
    aria-label="ページトップへ"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <script>
    const btn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn?.classList.remove('opacity-0', 'pointer-events-none');
        btn?.classList.add('opacity-100');
      } else {
        btn?.classList.add('opacity-0', 'pointer-events-none');
        btn?.classList.remove('opacity-100');
      }
    });
    btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>
</BaseLayout>

<style is:global>
/* ============================================
   HOKAN STATION - 記事本文スタイル
============================================ */
.article-body {
  font-size: 1rem;
  line-height: 2;
  color: #374151;
}
.article-body p {
  margin: 1.4em 0;
}
.article-body h2 {
  font-size: 1.2rem;
  font-weight: 800;
  color: #0c4a6e;
  margin: 2.8em 0 0.9em;
  padding: 0.6em 1em;
  background: linear-gradient(to right, #e0f2fe, #f0f9ff);
  border-left: 5px solid #0ea5e9;
  border-radius: 0 8px 8px 0;
  line-height: 1.5;
}
.article-body h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: #1e3a5f;
  margin: 2em 0 0.6em;
  padding: 0.4em 0.9em;
  border-left: 4px solid #10b981;
  background-color: #f0fdf4;
  border-radius: 0 6px 6px 0;
  line-height: 1.5;
}
.article-body h4 {
  font-size: 1rem;
  font-weight: 700;
  color: #374151;
  margin: 1.6em 0 0.5em;
  padding-left: 0.7em;
  border-left: 3px solid #94a3b8;
}
.article-body strong {
  font-weight: 700;
  color: #111827;
  background-color: #fef08a;
  padding: 0 3px;
  border-radius: 3px;
}
.article-body a {
  color: #0284c7;
  text-decoration: underline;
  text-decoration-color: #bae6fd;
  text-underline-offset: 3px;
}
.article-body a:hover {
  color: #075985;
  text-decoration-color: #0284c7;
}
.article-body ul {
  margin: 1.2em 0;
  padding: 0;
  list-style: none;
}
.article-body ul li {
  position: relative;
  padding: 0.3em 0 0.3em 1.8em;
  border-bottom: 1px dashed #e5e7eb;
}
.article-body ul li:last-child {
  border-bottom: none;
}
.article-body ul li::before {
  content: "▶";
  position: absolute;
  left: 0.3em;
  top: 0.4em;
  font-size: 0.55rem;
  color: #0ea5e9;
}
.article-body ol {
  margin: 1.2em 0;
  padding-left: 1.6em;
}
.article-body ol li {
  padding: 0.2em 0 0.2em 0.4em;
}
.article-body ol li::marker {
  color: #0369a1;
  font-weight: 700;
}
.article-body blockquote {
  margin: 1.6em 0;
  padding: 1em 1.2em;
  background-color: #f0fdf4;
  border-left: 5px solid #10b981;
  border-radius: 0 10px 10px 0;
  color: #374151;
  font-style: normal;
}
.article-body blockquote p {
  margin: 0;
}
.article-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.8em 0;
  font-size: 0.9rem;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
}
.article-body thead tr {
  background: linear-gradient(135deg, #0369a1, #0ea5e9);
  color: #fff;
}
.article-body thead th {
  padding: 0.75em 1.1em;
  text-align: left;
  font-weight: 700;
  font-size: 0.88rem;
  letter-spacing: 0.02em;
}
.article-body tbody tr {
  border-bottom: 1px solid #e5e7eb;
  transition: background 0.15s;
}
.article-body tbody tr:nth-child(even) {
  background-color: #f0f9ff;
}
.article-body tbody tr:hover {
  background-color: #e0f2fe;
}
.article-body tbody td {
  padding: 0.7em 1.1em;
  vertical-align: top;
  line-height: 1.7;
}
.article-body tbody td:first-child {
  font-weight: 600;
  color: #1e40af;
}
.article-body code {
  background-color: #f1f5f9;
  color: #be185d;
  padding: 0.15em 0.45em;
  border-radius: 4px;
  font-size: 0.875em;
  font-weight: 500;
}
.article-body pre {
  background-color: #1e293b;
  color: #e2e8f0;
  padding: 1.2em 1.5em;
  border-radius: 10px;
  overflow-x: auto;
  font-size: 0.875rem;
  line-height: 1.7;
  margin: 1.6em 0;
}
.article-body pre code {
  background: none;
  color: inherit;
  padding: 0;
  font-size: inherit;
}
.article-body hr {
  border: none;
  border-top: 2px dashed #e2e8f0;
  margin: 2.5em 0;
}
</style>
