---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';

const ARTICLES_PER_PAGE = 12;

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const totalPages = Math.ceil(allPosts.length / ARTICLES_PER_PAGE);
const currentPage = 1;
const posts = allPosts.slice(0, ARTICLES_PER_PAGE);
---

<BaseLayout
  title="HOKAN STATION"
  description="訪問看護に関わる看護師・ケアマネ・ご家族向けの専門情報メディア。疾患別ケア・制度・保険・キャリアなど毎日10本の記事を発信。"
>
  <Header />

  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-primary-700 to-primary-900 text-white py-10 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-2xl md:text-4xl font-bold mb-3">
          訪問看護の専門情報メディア
        </h1>
        <p class="text-primary-100 text-sm md:text-base max-w-xl mx-auto">
          訪問看護師・ケアマネジャー・ご家族に役立つ情報を毎日発信。<br class="hidden md:block" />
          疾患別ケア・制度・保険・キャリア・医療技術まで幅広くカバーします。
        </p>
        <div class="flex flex-wrap justify-center gap-2 mt-5">
          {['基礎知識', '疾患別ケア', '家族向け', '制度・保険', 'キャリア', '医療技術'].map((cat) => (
            <a
              href={`/category/${cat}/`}
              class="text-xs bg-white/20 hover:bg-white/30 text-white px-3 py-1.5 rounded-full transition-colors"
            >
              {cat}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles -->
    <section class="max-w-6xl mx-auto px-4 py-10">
      <h2 class="text-lg font-bold text-gray-800 mb-6 flex items-center gap-2">
        <span class="w-1 h-5 bg-primary-500 rounded-full inline-block"></span>
        最新記事
      </h2>

      {posts.length === 0 ? (
        <div class="text-center py-16 text-gray-500">
          <p class="text-lg">記事を準備中です。しばらくお待ちください。</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              publishDate={post.data.publishDate}
              category={post.data.category}
              tags={post.data.tags}
              slug={post.slug}
            />
          ))}
        </div>
      )}

      <Pagination currentPage={currentPage} totalPages={totalPages} baseURL="/" />
    </section>
  </main>

  <Footer />
</BaseLayout>
